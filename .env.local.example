# fal.ai API key — obtain from https://fal.ai/dashboard/keys
FAL_KEY=

# Model endpoint. Default は Flux dev img2img (安定動作)。
#   fal-ai/flux/dev/image-to-image   (推奨: 確実に動く, strength で効き調整)
#   fal-ai/flux-general              (ControlNet対応, 上級者向け)
FAL_MODEL=fal-ai/flux/dev/image-to-image

# img2img 強度 (0.0-1.0, 高いほど元を無視してスタイルに寄る)
FAL_STRENGTH=0.9

# 生成ステップ数と guidance_scale
FAL_STEPS=28
FAL_GUIDANCE=3.5
