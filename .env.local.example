# fal.ai API key — obtain from https://fal.ai/dashboard/keys
FAL_KEY=

# Model endpoint. Default uses depth ControlNet for strong style transfer
# while keeping room geometry.
#   fal-ai/flux-control-lora-depth   (推奨: 骨組みだけ保ちスタイルを大胆に変える)
#   fal-ai/flux-general              (ControlNetを細かく指定したい場合)
#   fal-ai/flux/dev/image-to-image   (素材感を残したいゆるめ変換)
FAL_MODEL=fal-ai/flux-control-lora-depth

# depth ControlNet の効き (0.0-1.0, 高いほど元の構造に厳密)
FAL_CONTROL_STRENGTH=0.85

# 生成ステップ数と guidance_scale
FAL_STEPS=28
FAL_GUIDANCE=10
