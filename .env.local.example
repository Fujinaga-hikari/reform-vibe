# fal.ai API key — obtain from https://fal.ai/dashboard/keys
FAL_KEY=

# Model endpoint. Default is Flux dev img2img (structure-preserving, fast).
#   fal-ai/flux/dev/image-to-image   (推奨: 構造保持+高品質)
#   fal-ai/flux-control-lora-depth   (より厳密に骨組み保持したい場合)
FAL_MODEL=fal-ai/flux/dev/image-to-image

# img2img 強度: 低いほど元写真に忠実、高いほどスタイルに寄る (0.0-1.0)
FAL_STRENGTH=0.75

# 生成ステップ数と guidance_scale (Fluxの推奨値)
FAL_STEPS=28
FAL_GUIDANCE=3.5
